{
  "name": "@openkyc/sdk",
  "version": "2.0.0",
  "description": "OpenKYC JavaScript SDK — device fingerprinting, RASP detection, and trust scoring for identity verification",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "keywords": [
    "kyc",
    "identity-verification",
    "fingerprint",
    "device-fingerprinting",
    "rasp",
    "fraud-detection",
    "biometric",
    "openkyc"
  ],
  "author": "OpenKYC <support@openkyc.cloud>",
  "license": "MIT",
  "homepage": "https://openkyc.cloud",
  "repository": {
    "type": "git",
    "url": "https://github.com/openkycofficial/openkyc-js.git"
  },
  "bugs": {
    "url": "https://github.com/openkycofficial/openkyc-js/issues"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {}
}
